FROM osrf/ros:humble-desktop-full

# Install packages
RUN apt update && apt install -y \
    build-essential \
    cmake \
    git \
    wget \
    curl \
    nano \
    vim \
    python3-pip \
    python3-colcon-common-extensions \
    python3-rosdep \
    python3-vcstool

RUN apt update && apt install -y \
    libeigen3-dev \
    libceres-dev \
    libsuitesparse-dev \
    libyaml-cpp-dev \
    libpcap-dev \
    libgoogle-glog-dev \
    libgflags-dev

# RViz2 and display dependencies
RUN apt update && apt install -y \
    ros-humble-rviz2 \
    libgl1-mesa-glx \
    libgl1-mesa-dri \
    mesa-utils \
    x11-apps \
    && rm -rf /var/lib/apt/lists/*

# Livox ROS2 driver
RUN mkdir -p /opt/livox_ws/src && \
    cd /opt/livox_ws/src && \
    git clone https://github.com/Livox-SDK/livox_ros_driver2.git && \
    cp /opt/livox_ws/src/livox_ros_driver2/package_ROS2.xml \
       /opt/livox_ws/src/livox_ros_driver2/package.xml

RUN /bin/bash -c "source /opt/ros/humble/setup.bash && \
    cd /opt/livox_ws && \
    colcon build --symlink-install --cmake-args -DCMAKE_BUILD_TYPE=Release \
    2>&1 | tee /opt/livox_build.log && \
    ls -la /opt/livox_ws/"

# Livox ROS2 driver
RUN mkdir -p /opt/livox_ws/src && \
    cd /opt/livox_ws/src && \
    git clone https://github.com/Livox-SDK/livox_ros_driver2.git && \
    cp /opt/livox_ws/src/livox_ros_driver2/package_ROS2.xml \
       /opt/livox_ws/src/livox_ros_driver2/package.xml

RUN /bin/bash -c "source /opt/ros/humble/setup.bash && \
    cd /opt/livox_ws/src/livox_ros_driver2 && \
    chmod +x build.sh && \
    ./build.sh"

# Display environment
ENV DISPLAY=:0
ENV QT_X11_NO_MITSHM=1
ENV ROS_DOMAIN_ID=7

RUN echo "source /opt/ros/humble/setup.bash" >> /root/.bashrc && \
    echo "source /opt/livox_ws/install/setup.bash" >> /root/.bashrc && \
    echo "if [ -f /ros2_ws/install/setup.bash ]; then source /ros2_ws/install/setup.bash; fi" >> /root/.bashrc

WORKDIR /ros2_ws