    libgflags-dev libboost-all-dev libpcl-dev \
    && rm -rf /var/lib/apt/lists/*

RUN apt update && apt install -y \
    ros-humble-rviz2 libgl1-mesa-glx libgl1-mesa-dri \
    mesa-utils x11-apps ros-humble-rmw-cyclonedds-cpp \
    && rm -rf /var/lib/apt/lists/*

